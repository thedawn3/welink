# Copy this file to .env before running docker compose.
# Recommended: let the doctor script generate/overwrite .env for you.
#   macOS/Linux: ./scripts/welink-doctor.sh --write-env
#   PowerShell:  ./scripts/welink-doctor.ps1 -WriteEnv

WELINK_BACKEND_PORT=8080
WELINK_FRONTEND_PORT=3000
WELINK_GIN_MODE=release

# Required: decrypted WeChat database root.
# Must contain:
#   contact/contact.db
#   message/message_*.db
#
# macOS example:
# WELINK_DATA_DIR=/Users/you/work/wechat-decrypt/decrypted_with_wal
#
# Windows example (use forward slashes):
# WELINK_DATA_DIR=C:/Users/you/work/wechat-decrypt/decrypted_with_wal
WELINK_DATA_DIR=./decrypted

# Optional: WeChat media directory (images/videos/files).
# If left empty, compose falls back to ./.tmp/welink-empty-msg.
#
# macOS example:
# WELINK_MSG_DIR=/Users/you/Library/Containers/com.tencent.xinWeChat/Data/Documents/xwechat_files/wxid_xxx/msg
#
# Windows example (use forward slashes):
# WELINK_MSG_DIR=C:/Users/you/Documents/WeChat Files/wxid_xxx/msg
WELINK_MSG_DIR=
