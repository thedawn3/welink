# Recommended: let the doctor script generate/overwrite .env for you.
#   macOS/Linux: ./scripts/welink-doctor.sh --mode analysis-only --data-dir /abs/path --write-env
#   PowerShell : .\scripts\welink-doctor.ps1 -Mode analysis-only -DataDir 'C:/abs/path' -WriteEnv

WELINK_BACKEND_PORT=8080
WELINK_FRONTEND_PORT=3000
WELINK_GIN_MODE=release

# -------------------------------------------------------------------
# Docker canonical mode A: analysis-only
# -------------------------------------------------------------------
# Standard directory contract:
#   contact/contact.db
#   message/message_*.db
#   sns/sns.db                # optional

# analysis directory (required)
WELINK_ANALYSIS_DATA_DIR=./decrypted

# Keep equal to WELINK_ANALYSIS_DATA_DIR for legacy compatibility
WELINK_DATA_DIR=./decrypted

# Optional media directory (for image previews)
WELINK_MSG_DIR=

# Optional wechat-decrypt tool directory (for image_keys.json / config.json)
WELINK_WECHAT_DECRYPT_DIR=

# Optional image key overrides
WELINK_IMAGE_AES_KEY=
WELINK_IMAGE_AES_KEY_FILE=
WELINK_WECHAT_DECRYPT_CONFIG=

# analysis-only keeps source empty; compose mounts an empty placeholder
WELINK_SOURCE_DATA_DIR=

# Writable temp work directory
WELINK_WORK_DIR=./.tmp/welink-workdir

WELINK_MODE=analysis-only
WELINK_PLATFORM=auto
WELINK_INGEST_ENABLED=false
WELINK_DECRYPT_ENABLED=false
WELINK_DECRYPT_AUTO_START=false
WELINK_SYNC_ENABLED=false

# -------------------------------------------------------------------
# Docker canonical mode B: manual-sync
# -------------------------------------------------------------------
# To switch from analysis-only to manual-sync, change at least:
# WELINK_MODE=manual-sync
# WELINK_SOURCE_DATA_DIR=/absolute/path/to/source_standard_dir
#
# Rules:
# - source must also be a standard directory root
# - do not point source and analysis to the same directory
# - do not point source to raw xwechat_files root

# -------------------------------------------------------------------
# Advanced local/native options (not required for Docker acceptance)
# -------------------------------------------------------------------
WELINK_SYNC_WATCH_WAL=true
WELINK_SYNC_DEBOUNCE_MS=1000
WELINK_SYNC_MAX_WAIT_MS=10000
WELINK_SYNC_EVENT_BUFFER=128

WELINK_DECRYPT_PROVIDER=builtin
WELINK_WINDOWS_DECRYPT_COMMAND=
WELINK_MAC_DECRYPT_COMMAND=
WELINK_LINUX_DECRYPT_COMMAND=
WELINK_DECRYPT_PRESERVE_WAL=false
WELINK_DECRYPT_TIMEOUT_SECONDS=120

WELINK_RUNTIME_ENGINE_TYPE=welink
WELINK_RUNTIME_MAX_TASK_RECORDS=200
WELINK_RUNTIME_MAX_LOG_RECORDS=1000
