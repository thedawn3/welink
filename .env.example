# Copy this file to .env before running docker compose.
# Recommended: let the doctor script generate/overwrite .env for you.
#   macOS/Linux: ./scripts/welink-doctor.sh --write-env
#   PowerShell:  ./scripts/welink-doctor.ps1 -WriteEnv

WELINK_BACKEND_PORT=8080
WELINK_FRONTEND_PORT=3000
WELINK_GIN_MODE=release

# -------------------------------------------------------------------
# Docker canonical mode A: analysis-only（默认）
# 只消费 analysis directory，不提供 source standard directory。
#
# 标准目录契约（source / analysis 都遵循）：
#   contact/contact.db
#   message/message_*.db
#   sns/sns.db                # 可选，已验证 ylytdeng/wechat-decrypt 可产出
# -------------------------------------------------------------------

# analysis directory（容器内 /app/analysis-data）: 必填
# macOS:   /Users/you/work/wechat/decrypted_standard
# Windows: C:/Users/you/work/wechat/decrypted_standard
WELINK_ANALYSIS_DATA_DIR=./decrypted

# 兼容旧逻辑，建议保持与 WELINK_ANALYSIS_DATA_DIR 一致
WELINK_DATA_DIR=./decrypted

# media directory（容器内 /app/msg）: 可选，不影响文本分析
WELINK_MSG_DIR=

# source standard directory（容器内 /app/source-data）:
# analysis-only 下保持为空；compose 会挂载空占位目录。
# 留空时 compose 会挂载空占位目录 ./.tmp/welink-empty-source
WELINK_SOURCE_DATA_DIR=

# work directory（容器内 /app/workdir）: 用于内置 stage 临时文件
WELINK_WORK_DIR=./.tmp/welink-workdir

# analysis-only 默认关闭 ingest/decrypt/sync 自动链路（安全默认）
WELINK_MODE=analysis-only
WELINK_PLATFORM=auto
WELINK_INGEST_ENABLED=false
WELINK_DECRYPT_ENABLED=false
WELINK_DECRYPT_AUTO_START=false
WELINK_SYNC_ENABLED=false

# -------------------------------------------------------------------
# Docker canonical mode B: manual-sync
# 切换到手动同步标准目录时，至少改这几项：
#
# WELINK_MODE=manual-sync
# WELINK_SOURCE_DATA_DIR=/absolute/path/to/source_standard_dir
# WELINK_INGEST_ENABLED=false
# WELINK_DECRYPT_ENABLED=false
# WELINK_DECRYPT_AUTO_START=false
# WELINK_SYNC_ENABLED=false
#
# 说明：
# - analysis directory 继续指向 WeLink 当前分析目录
# - source standard directory 必须是标准目录根，而不是 xwechat_files 原始根目录
# - Docker 首期仍不推荐容器内 watcher/auto refresh
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# 本地原生/高级链路（按需开启）
# -------------------------------------------------------------------

WELINK_SYNC_WATCH_WAL=true
WELINK_SYNC_DEBOUNCE_MS=1000
WELINK_SYNC_MAX_WAIT_MS=10000
WELINK_SYNC_EVENT_BUFFER=128

# 解密命令模板支持：
#   ${platform} ${source_data_dir} ${analysis_data_dir} ${work_dir} ${auto_refresh} ${wal_enabled}
WELINK_DECRYPT_PROVIDER=builtin
WELINK_WINDOWS_DECRYPT_COMMAND=
WELINK_MAC_DECRYPT_COMMAND=
WELINK_LINUX_DECRYPT_COMMAND=
WELINK_DECRYPT_PRESERVE_WAL=false
WELINK_DECRYPT_TIMEOUT_SECONDS=120

# 运行时状态保留
WELINK_RUNTIME_ENGINE_TYPE=welink
WELINK_RUNTIME_MAX_TASK_RECORDS=200
WELINK_RUNTIME_MAX_LOG_RECORDS=1000
